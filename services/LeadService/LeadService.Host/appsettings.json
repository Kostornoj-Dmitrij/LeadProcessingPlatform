{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "LeadService": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=lead_db;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "lead-service",
    "DlqTopic": "lead-service-dlq",
    "ConsumerMaxPollIntervalMs": 300000,
    "ConsumerSessionTimeoutMs": 30000,
    "ProducerEnableIdempotence": true,
    "ProducerMaxRetries": 3
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:18889"
  },
  "AllowedHosts": "*"
}
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.EntityFrameworkCore.Query": "Warning",
      "LeadService": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=lead_db;Username=postgres;Password=postgres;Maximum Pool Size=50;Minimum Pool Size=5;Connection Idle Lifetime=300;Connection Pruning Interval=10;Include Error Detail=true"
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "SchemaRegistryUrl": "http://schema-registry:8085",
    "GroupId": "lead-service",
    "DlqTopic": "lead-service-dlq",
    "ConsumerMaxPollIntervalMs": 300000,
    "ConsumerSessionTimeoutMs": 30000,
    "ProducerEnableIdempotence": true,
    "ProducerMaxRetries": 3
  },
  "OpenTelemetry": {
    "Endpoint": "http://aspire-dashboard:4317",
    "Protocol": "Grpc",
    "EnableTracing": true,
    "EnableMetrics": true
  },
  "AllowedHosts": "*"
}
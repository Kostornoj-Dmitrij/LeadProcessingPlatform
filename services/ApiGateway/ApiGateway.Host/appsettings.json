{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "lead-route": {
        "ClusterId": "lead-cluster",
        "Match": {
          "Path": "/api/leads/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "lead-cluster": {
        "Destinations": {
          "lead-service": {
            "Address": "http://lead-service:80/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information",
      "Microsoft.AspNetCore.HttpLogging": "Information",
      "Microsoft.AspNetCore.Authentication": "Information"
    },
    "CategoryLevels": {
      "Microsoft.AspNetCore.HttpLogging": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "LeadProcessingPlatform",
    "Audience": "LeadProcessingClients"
  },
  "Auth": {
    "ApiKeys": {
      "partner-system": "dev-api-key",
      "internal-client": "internal-key",
      "test-client": "test-key"
    }
  },
  "OpenTelemetry": {
    "Endpoint": "http://aspire-dashboard:4317",
    "Protocol": "Grpc",
    "EnableTracing": true,
    "EnableMetrics": true,
    "FilterBackgroundQueries": true,
    "DisabledMetrics": []
  },
  "ReverseProxy": {
    "Routes": {
      "lead-service-route": {
        "ClusterId": "lead-service-cluster",
        "Match": {
          "Path": "/api/leads/{**catch-all}"
        },
        "AuthorizationPolicy": "ApiAccess",
        "Transforms": [
          { "PathPattern": "/api/leads/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "lead-service-cluster": {
        "Destinations": {
          "lead-service-destination": {
            "Address": "http://lead-service:80/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}